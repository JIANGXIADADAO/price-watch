{
  "manifest_version": 3,
  "name": "Price Watch",
  "version": "0.1.0",
  "description": "Monitor product prices on any page. Get webhook alerts when prices change.",
  "permissions": ["storage", "alarms", "scripting", "activeTab", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["picker.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
